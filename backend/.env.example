APP_NAME=MedSpeak API
APP_ENV=development
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DAILY_LIMIT=5
REQUEST_CHAR_LIMIT=16000
MAX_FILE_SIZE_KB=150
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
OPENAI_ANALYST_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RUNTIME_JUDGE_ENABLED=true
RUNTIME_JUDGE_MODEL=gpt-4o-mini
RUNTIME_JUDGE_FAIL_CLOSED=true
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
CHROMA_PERSIST_DIRECTORY=data/chroma
# Production override example:
# CHROMA_PERSIST_DIRECTORY=/var/data/chroma
RETRIEVAL_TOP_K=3
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY_SECONDS=0.5
